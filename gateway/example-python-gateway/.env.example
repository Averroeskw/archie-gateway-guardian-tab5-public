# Copy to .env and fill in. The gateway loads .env automatically.
# .env is gitignored — your real key never gets committed.

# --- security (set this!) ---------------------------------------------------
# Shared secret the Tab5 must present. Generate one: openssl rand -hex 24
HERMES_GATEWAY_TOKEN=

# --- LLM: just pick a provider and paste a key ------------------------------
# Provider preset picks the base URL + a sensible default model.
#   openai | openrouter | groq | together | deepseek | mistral | ollama | llamacpp | custom
LLM_PROVIDER=openai

# Your API key. Not needed for local ollama/llamacpp.
LLM_API_KEY=

# Optional: override the model (else the provider default is used).
# LLM_MODEL=gpt-4o-mini

# Optional: override the endpoint (required when LLM_PROVIDER=custom).
# LLM_BASE_URL=https://api.openai.com/v1

# Optional: tweak the persona/system prompt ("{persona}" is substituted).
# LLM_SYSTEM_PROMPT=You are {persona}, a concise handheld assistant.

# Optional: conversation memory depth (past messages resent per request).
# LLM_HISTORY_MAX=12

# --- server -----------------------------------------------------------------
# HERMES_GATEWAY_PORT=8787
# HERMES_GATEWAY_BIND=0.0.0.0

# ---------------------------------------------------------------------------
# Quick recipes:
#   OpenAI:      LLM_PROVIDER=openai      LLM_API_KEY=<provider-key>
#   OpenRouter:  LLM_PROVIDER=openrouter  LLM_API_KEY=<provider-key>   (any supported model)
#   Groq:        LLM_PROVIDER=groq        LLM_API_KEY=<provider-key>
#   Local Ollama: LLM_PROVIDER=ollama     LLM_MODEL=llama3.2      (no key; run `ollama serve`)
